<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Document</title>
    <link rel="stylesheet" href="/details.css" />
  </head>
  <body>
    <div class="item">
      <h1><%=item.name %></h1>
      <img src="/<%= item.photo %>" alt="<%= item.name %>" />
      <h2 class="price">Price: <%= item.price %></h2>
      <h3 class="cat">Category :<%=item.category %></h3>
      <h3 class="rat">Rating :<%=item.rating %> &#9733;</h3>
      <h3 class="des"><span>description : </span><%=item.description %></h3>
    </div>
    <a href="/foodList">Go to main menu</a>
  </body>
</html>
