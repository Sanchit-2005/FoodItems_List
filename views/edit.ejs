<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>
<body>
    <h1>Edit  the item </h1>
   <form method="POST" action="/foods/<%=item.id%>?_method=PATCH" enctype="multipart/form-data">
         <h2>Name:  <input type="text" name="name" value="<%=item.name %>"></h2>
         <h2>Price : <input type="text" name="price" value="<%=item.price %>"></h2>
         <h2>Category:   <input type="text" name="category" value="<%=item.category %>">  </h2>
            <h2>Image: <input type="file" name="photo"></h2>
            <!-- he pn nhi mahit  -->
            <h2>Item available <input type="checkbox" name="available"  <%=item.available ?'checked':''%> ></h2>  

            <h2>Description <input type="text" name="description" value="<%=item.description %>"></h2>
            <h2>Rating <input type="text" name="rating" value="<%=item.rating %>"></h2>

         <button> submit </button>
   </form>
    
</body>
</html>